{
  "name": "loomapos-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:all": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-all.ps1",
    "dev:all:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-all.ps1",
    "dev:api": "dotnet watch --project apps/api/src/LoomaPos.Api/LoomaPos.Api.csproj",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "turbo run format",
    "validate:features": "node scripts/ops/validate-feature-content.mjs",
    "validate:features:test": "node scripts/ops/test-feature-content-guard.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
