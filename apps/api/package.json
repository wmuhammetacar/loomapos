{
  "name": "@loomapos/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "dotnet build src/LoomaPos.Api/LoomaPos.Api.csproj",
    "dev": "dotnet watch --project src/LoomaPos.Api/LoomaPos.Api.csproj",
    "test": "dotnet test tests/LoomaPos.UnitTests/LoomaPos.UnitTests.csproj && dotnet test tests/LoomaPos.IntegrationTests/LoomaPos.IntegrationTests.csproj",
    "nswag:generate": "dotnet tool restore && dotnet tool run nswag run nswag.json",
    "migrate:add": "dotnet tool run dotnet-ef migrations add InitialCreate --project src/LoomaPos.Api/LoomaPos.Api.csproj --startup-project src/LoomaPos.Api/LoomaPos.Api.csproj --output-dir Persistence/Migrations",
    "migrate:update": "dotnet tool run dotnet-ef database update --project src/LoomaPos.Api/LoomaPos.Api.csproj --startup-project src/LoomaPos.Api/LoomaPos.Api.csproj",
    "lint": "dotnet build src/LoomaPos.Api/LoomaPos.Api.csproj -warnaserror",
    "format": "dotnet format LoomaPos.sln --verify-no-changes",
    "node:dev": "tsx watch src-node/server.ts",
    "node:build": "tsc -p tsconfig.node.json",
    "node:start": "node dist-node/src-node/server.js",
    "node:typecheck": "tsc -p tsconfig.node.json --noEmit",
    "node:test": "vitest run --config vitest.config.ts",
    "node:prisma:generate": "prisma generate",
    "node:prisma:migrate": "prisma migrate dev",
    "node:prisma:push": "prisma db push",
    "node:seed": "tsx scripts/seed-node.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.6.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
