generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  fullName    String   @map("full_name")
  companyName String   @map("company_name")
  email       String   @unique
  phone       String?
  status      String   @default("prospect")
  createdAt   DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]
  licenses      License[]
  billing       BillingRecord[]

  @@map("customers")
}

model Subscription {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  customerId         String   @map("customer_id")
  planCode           String   @map("plan_code")
  billingCycle       String   @map("billing_cycle")
  status             String   @default("active")
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  resellerCode       String?  @map("reseller_code")
  createdAt          DateTime @default(now()) @map("created_at")

  customer Customer       @relation(fields: [customerId], references: [id])
  licenses License[]
  billing  BillingRecord[]

  @@map("subscriptions")
}

model License {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  customerId    String   @map("customer_id")
  subscriptionId String  @map("subscription_id")
  licenseKey    String   @unique @map("license_key")
  planCode      String   @map("plan_code")
  issuedAt      DateTime @default(now()) @map("issued_at")
  expiresAt     DateTime @map("expires_at")
  status        String   @default("active")
  deviceLimit   Int?     @map("device_limit")
  featureFlags  Json     @map("feature_flags")

  customer     Customer          @relation(fields: [customerId], references: [id])
  subscription Subscription      @relation(fields: [subscriptionId], references: [id])
  devices      DeviceActivation[]

  @@map("licenses")
}

model BillingRecord {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  customerId    String   @map("customer_id")
  subscriptionId String  @map("subscription_id")
  invoiceNo     String   @unique @map("invoice_no")
  provider      String
  paymentMethod String   @map("payment_method")
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("TRY")
  status        String   @default("paid")
  issuedAt      DateTime @default(now()) @map("issued_at")
  paidAt        DateTime? @map("paid_at")

  customer     Customer     @relation(fields: [customerId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("billing_records")
}

model DeviceActivation {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  licenseId   String   @map("license_id")
  deviceName  String   @map("device_name")
  platform    String
  appVersion  String?  @map("app_version")
  activatedAt DateTime @default(now()) @map("activated_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")

  license License @relation(fields: [licenseId], references: [id])

  @@map("device_activations")
}

model ResellerLead {
  id                  String   @id @default(cuid())
  fullName            String   @map("full_name")
  companyName         String   @map("company_name")
  city                String
  phone               String
  email               String   @unique
  websiteOrSocialProof String  @map("website_or_social_proof")
  experience          String
  message             String
  status              String   @default("pending")
  referralCode        String   @unique @map("referral_code")
  commissionRate      Decimal  @default(0.10) @map("commission_rate") @db.Decimal(5, 2)
  createdAt           DateTime @default(now()) @map("created_at")

  commissions ResellerCommission[]

  @@map("reseller_leads")
}

model ResellerCommission {
  id           String   @id @default(cuid())
  resellerId   String   @map("reseller_id")
  tenantId     String   @map("tenant_id")
  subscriptionId String @map("subscription_id")
  amount       Decimal  @db.Decimal(12, 2)
  rate         Decimal  @db.Decimal(5, 2)
  status       String   @default("accrued")
  createdAt    DateTime @default(now()) @map("created_at")

  reseller ResellerLead @relation(fields: [resellerId], references: [id])

  @@map("reseller_commissions")
}
