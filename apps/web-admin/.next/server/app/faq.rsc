11:Tdf8,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Planlarin farki nedir?","acceptedAnswer":{"@type":"Answer","text":"Fark; sube, cihaz ve personel limitleri ile destek seviyesidir. Tum planlar lisans ve indirme akisini icerir."}},{"@type":"Question","name":"Yillik odemede ne kazanirim?","acceptedAnswer":{"@type":"Answer","text":"Daha stabil butce planlamasi, tek yenileme tarihi ve ticari indirim avantajina sahip olursunuz."}},{"@type":"Question","name":"Lisans anahtarim nerede?","acceptedAnswer":{"@type":"Answer","text":"Odeme sonrasi success ekraninda ve musteri portali altindaki Licenses bolumunde gosterilir."}},{"@type":"Question","name":"Lisans suresi dolarsa ne olur?","acceptedAnswer":{"@type":"Answer","text":"Portal yenileme ve faturalama bilgisini guncel tutar; operasyonel runtime davranisi Desktop ve Mobile uygulamalarda uygulanir."}},{"@type":"Question","name":"Indirmeler herkese acik mi?","acceptedAnswer":{"@type":"Answer","text":"Public sayfada teaser ve bilgi yer alir. Lisansli kurulum paketleri portal erisimi ile gosterilir."}},{"@type":"Question","name":"Kurulum notlarini nerede bulurum?","acceptedAnswer":{"@type":"Answer","text":"Download sayfasinda release notes, minimum gereksinimler ve aktivasyon adimlari bulunur."}},{"@type":"Question","name":"Aktivasyon icin internet gerekli mi?","acceptedAnswer":{"@type":"Answer","text":"Ilk aktivasyon ve lisans dogrulamasi icin internet gerekir. Sonrasindaki runtime kurallari istemci politikasina gore devam eder."}},{"@type":"Question","name":"Cihaz limiti nasil kontrol edilir?","acceptedAnswer":{"@type":"Answer","text":"Portal altindaki Devices sayfasi aktif cihaz sayisini ve plan limitini gosterir."}},{"@type":"Question","name":"Ek cihaz tanimlamak icin ne yapmaliyim?","acceptedAnswer":{"@type":"Answer","text":"Plan yukseltin veya mevcut cihaz esiklerini portal uzerinden kontrol ederek destek ekibiyle iletisime gecin."}},{"@type":"Question","name":"Web sitesi